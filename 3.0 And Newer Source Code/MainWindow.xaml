<Window x:Class="C2O.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CTRL 2 OSC" Height="900" Width="950"
        Background="#3C444E" Foreground="White"
        Closing="Window_Closing">

    <Window.Resources>
        <Style TargetType="Expander">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding Header}" 
                                          Cursor="Hand"
                                          Background="#2F353D"
                                          BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="15,10">
                                            <ContentPresenter Content="{TemplateBinding Content}" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter x:Name="ExpandSite" Content="{TemplateBinding Content}" Visibility="Collapsed" Margin="{TemplateBinding Padding}"/>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <TabControl Background="#3C444E" BorderBrush="#2C3239" Foreground="White">
            
            <TabItem Header="About C2O">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="30,20,30,30">
                        <TextBlock Text="Controller 2 OSC (C2O)" Foreground="#DFBB3F" FontSize="28" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock Text="C# Edition V3.3 Motion &amp; FFB Update" Foreground="#717171" FontSize="14" FontWeight="Bold" Margin="0,0,0,20"/>
                        
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,10" LineHeight="20">
                            C2O is a lightweight, GUI-driven application designed to seamlessly bridge the gap between physical hardware and digital environments.
                            It reads real-time data from connected USB steering wheels, Bluetooth gamepads, joysticks, and keyboards.
                            Capturing everything from continuous analog axes (like pedals and throttles) to discrete button presses and D-pad movements.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,10" LineHeight="20">
                            The application translates and broadcasts these inputs over a local network using the Open Sound Control (OSC) protocol, ensuring extremely low-latency communication without the need for heavy middleware.
                        </TextBlock>
                        <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,20" LineHeight="20">
                            C2O was developed as a versatile solution for mapping physical simulation hardware to Massive Loop.
                        </TextBlock>
                        <TextBlock Text="Programmed by Brandon Withington" Foreground="#33FF00" FontSize="14" FontWeight="Bold" Margin="0,0,0,30"/>

                        <TextBlock Text="OSC Payload Formats" Foreground="#DFBB3F" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                        <Border Background="#2F353D" CornerRadius="6" Padding="15" Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Outgoing Inputs" Foreground="#DFBB3F" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="[Address] &quot;axis&quot; [Mapped ID] [Float Value]"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="[Address] &quot;button&quot; [Mapped ID] [Int Value (0/1)]"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="[Address] &quot;hat&quot; [Mapped ID] [Int X] [Int Y]"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,10" Text="[Address] &quot;keyboard&quot; [Mapped ID] [Int Value (0/1)]"/>

                                <TextBlock Text="Incoming Force Feedback (FFB)" Foreground="#DFBB3F" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/force    [Float 0-100] -> Adjusts constant Cartesian pull"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/spring   [Float 0-100] -> Adjusts centering resistance"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/damper   [Float 0-100] -> Adjusts dynamic wheel weight"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/ffb/friction [Float 0-100] -> Adjusts static friction"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,10" Text="/ffb/rumble   [Float 0-100] -> Triggers standard gamepad rumble"/>

                                <TextBlock Text="Incoming Motion Telemetry (6-DoF)" Foreground="#DFBB3F" FontSize="16" FontWeight="Bold" Margin="0,10,0,10"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/motion/pitch [Float] -> Forward/Backward Tilt"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/motion/roll  [Float] -> Left/Right Tilt"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/motion/yaw   [Float] -> Left/Right Rotation"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/motion/surge [Float] -> Forward/Backward Acceleration"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,5" Text="/motion/sway  [Float] -> Left/Right Acceleration"/>
                                <TextBlock Foreground="White" FontSize="13" FontFamily="Consolas" Margin="0,0,0,10" Text="/motion/heave [Float] -> Up/Down Acceleration"/>
                                <TextBlock Foreground="#A0A0A0" FontSize="12" FontStyle="Italic" TextWrapping="Wrap" Margin="0,0,0,5" Text="Note: Incoming motion data is processed through C2O's per-axis washout filters and gain settings before being forwarded to your rig via Raw OSC or SimTools formatted strings."/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Output Settings">
                <Grid Margin="20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <GroupBox BorderThickness="0" Padding="15">
                        <GroupBox.Header>
                            <TextBlock Text="OSC Targeting &amp; Listening" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                        </GroupBox.Header>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="Target IP:" Grid.Row="0" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TargetIpEntry" Text="127.0.0.1" Grid.Row="0" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                            <TextBlock Text="Target Port (Send):" Grid.Row="1" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="TargetPortEntry" Text="4041" Grid.Row="1" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                            <TextBlock Text="Listen IP (Reception):" Grid.Row="2" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="ListenIpEntry" Text="0.0.0.0" Grid.Row="2" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5" ToolTip="Use 0.0.0.0 to listen on all network interfaces, or specify a specific IP."/>

                            <TextBlock Text="Listen Port (FFB In):" Grid.Row="3" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="ListenPortEntry" Text="4042" Grid.Row="3" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                            <TextBlock Text="Base OSC Address:" Grid.Row="4" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                            <TextBox x:Name="BaseAddrEntry" Text="/wheel/input" Grid.Row="4" Grid.Column="1" Margin="0,5,0,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>
                        </Grid>
                    </GroupBox>

                    <Grid Grid.Row="1" Margin="0,15,0,15">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Orientation="Horizontal" Grid.Column="0">
                            <Button x:Name="BtnToggleStream" Content="Start Streaming" Width="150" Height="35" Background="#28A745" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnToggleStream_Click"/>
                            <Button x:Name="BtnClearLog" Content="Clear Log" Width="100" Height="35" Margin="10,0,0,0" Background="#CC2900" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnClearLog_Click"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center" Margin="0,0,15,0">
                            <TextBlock Text="Output Style:" Foreground="#DFBB3F" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                            <RadioButton x:Name="RadioScroll" Content="Scrolling Log" IsChecked="True" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center" Checked="OutputStyle_Changed"/>
                            <RadioButton x:Name="RadioInPlace" Content="In-Place Dashboard" Foreground="White" VerticalAlignment="Center" Checked="OutputStyle_Changed"/>
                        </StackPanel>
                        
                        <Image x:Name="StatusIcon" Grid.Column="3" Width="36" Height="36" VerticalAlignment="Center"/>
                    </Grid>

                    <TextBox x:Name="LogArea" Grid.Row="2" Background="#2F353D" Foreground="#33FF00" FontFamily="Consolas" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" BorderBrush="#717171" Padding="10"/>
                </Grid>
            </TabItem>

            <TabItem Header="Input Settings">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Profile Management" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,10,0,0">
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Active Profile:" Foreground="White" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                    <ComboBox x:Name="ProfileDropdown" Width="200" Background="#717171" Foreground="#2F353D" FontSize="14" BorderThickness="0" Padding="5" SelectionChanged="ProfileDropdown_SelectionChanged">
                                        <ComboBox.Resources>
                                            <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#717171" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2F353D" />
                                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                        </ComboBox.Resources>
                                        <ComboBox.ItemContainerStyle>
                                            <Style TargetType="ComboBoxItem">
                                                <Setter Property="Background" Value="#717171"/>
                                                <Setter Property="Foreground" Value="White"/>
                                                <Setter Property="Padding" Value="5"/>
                                            </Style>
                                        </ComboBox.ItemContainerStyle>
                                    </ComboBox>
                                    
                                    <Button x:Name="BtnDeleteProfile" Content="Delete Profile" Width="110" Margin="10,0,0,0" Background="#9C0E0E" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnDeleteProfile_Click"/>
                                    <Button x:Name="BtnSaveConfig" Content="Save Configs Now" Width="130" Margin="10,0,0,0" Background="#0052CC" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnSaveConfig_Click"/>
                                </StackPanel>

                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBox x:Name="NewProfileNameEntry" Width="200" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>
                                    <Button x:Name="BtnNewProfile" Content="Clone to New Profile" Width="150" Margin="10,0,0,0" Background="#009952" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnNewProfile_Click"/>
                                    
                                    <Border Width="1" Background="#717171" Margin="20,0,20,0"/>
                                    <Button x:Name="BtnImportProfile" Content="Import .json" Width="100" Margin="0,0,10,0" Background="#2F353D" Foreground="#DFBB3F" BorderThickness="0" FontWeight="Bold" Click="BtnImportProfile_Click"/>
                                    <Button x:Name="BtnExportProfile" Content="Export .json" Width="100" Background="#2F353D" Foreground="#DFBB3F" BorderThickness="0" FontWeight="Bold" Click="BtnExportProfile_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Expander>

                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Input Device" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                <ComboBox x:Name="DeviceDropdown" Width="250" Background="#717171" Foreground="#2F353D" FontSize="14" BorderThickness="0" Padding="5">
                                    <ComboBox.Resources>
                                        <SolidColorBrush x:Key="{x:Static SystemColors.WindowBrushKey}" Color="#717171" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#2F353D" />
                                        <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White" />
                                    </ComboBox.Resources>
                                </ComboBox>
                                
                                <Button x:Name="BtnAddDevice" Content="Add Device" Width="100" Margin="10,0,0,0" Background="#009952" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnAddDevice_Click"/>
                                <Button x:Name="BtnClearDevices" Content="Clear Devices" Width="100" Margin="10,0,0,0" Background="#9C0E0E" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnClearDevices_Click"/>
                                <Button Content="Refresh" Width="80" Margin="10,0,0,0" Background="#0052CC" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnRefresh_Click"/>
                            </StackPanel>
                        </Expander>
                        
                        <StackPanel x:Name="DynamicSettingsPanel" Margin="0,0,0,0"/>
                        
                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Global Keyboard Mapping" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <WrapPanel x:Name="KeyboardSettingsPanel" Margin="0,10,0,0"/>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Force Feedback &amp; Motion">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="20">
                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Haptic Force Feedback Settings" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,5">
                                    Configure global scaling for incoming OSC FFB signals. These affect connected devices that support SDL Haptics (like Direct Drive wheels and standard FFB joysticks).
                                </TextBlock>
                                
                                <CheckBox x:Name="ChkFfbEnable" Content="Enable Force Feedback Processing" Foreground="White" FontWeight="Bold" IsChecked="True" Margin="0,0,0,15"/>
                                
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                    <TextBlock Text="Global FFB Gain:" Width="120" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <Slider x:Name="SliderFfbGain" Minimum="0" Maximum="2.0" Value="1.0" Width="200" TickFrequency="0.1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                    <TextBlock x:Name="TxtFfbGain" Text="1.0" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Width="30"/>
                                    
                                    <Ellipse x:Name="FfbClipIndicator" Width="16" Height="16" Fill="#2F353D" Margin="20,0,0,0" ToolTip="Flashes Red when FFB signal is clipping (exceeding 100%)"/>
                                    <TextBlock Text="Clipping Monitor" Foreground="White" VerticalAlignment="Center" Margin="5,0,0,0"/>
                                </StackPanel>

                                <Border Background="#2F353D" CornerRadius="6" Padding="15" Margin="0,15,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Custom FFB Test Tool" Foreground="#DFBB3F" FontWeight="Bold" Margin="0,0,0,10"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Test Strength:" Width="120" Foreground="White" VerticalAlignment="Center"/>
                                            <Slider x:Name="SliderTestStrength" Minimum="1" Maximum="100" Value="75" Width="200" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtTestStrength" Text="75 %" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Width="50"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="Pulse Duration:" Width="120" Foreground="White" VerticalAlignment="Center"/>
                                            <Slider x:Name="SliderTestDuration" Minimum="50" Maximum="2000" Value="250" Width="200" TickFrequency="50" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtTestDuration" Text="250 ms" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Width="50"/>
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                            <TextBlock Text="Pulse Count:" Width="120" Foreground="White" VerticalAlignment="Center"/>
                                            <Slider x:Name="SliderTestPulses" Minimum="1" Maximum="10" Value="2" Width="200" TickFrequency="1" IsSnapToTickEnabled="True" VerticalAlignment="Center"/>
                                            <TextBlock x:Name="TxtTestPulses" Text="2" Foreground="White" VerticalAlignment="Center" Margin="10,0,0,0" Width="50"/>
                                        </StackPanel>
                                        <Button x:Name="BtnTestFfb" Content="Execute FFB Test" Width="150" Height="30" HorizontalAlignment="Left" Background="#0052CC" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnTestFfb_Click"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Expander>

                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Motion Platform Forwarding" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,10,0,0">
                                <TextBlock TextWrapping="Wrap" Foreground="White" FontSize="14" Margin="0,0,0,15">
                                    Route incoming OSC telemetry straight to your motion platform's UDP port. Support for raw OSC or translated SimTools string payloads. Features Per-Axis High-Pass Washout Filters and Safety Heartbeat.
                                </TextBlock>
                                
                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox x:Name="ChkMotionEnable" Grid.Column="0" Content="Enable Motion Forwarding" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"/>
                                    
                                    <Button x:Name="BtnMotionKill" Grid.Column="2" Content="MOTION KILL SWITCH" Background="#B30000" Foreground="White" FontWeight="Bold" FontSize="14" Padding="15,5" BorderThickness="0" Click="BtnMotionKill_Click" Cursor="Hand"/>
                                </Grid>

                                <Grid Margin="0,0,0,15">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="200"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Rig IP Address:" Grid.Row="0" Grid.Column="0" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBox x:Name="MotionIpEntry" Text="127.0.0.1" Grid.Row="0" Grid.Column="1" Margin="0,5,15,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                                    <TextBlock Text="Rig UDP Port:" Grid.Row="1" Grid.Column="0" Margin="0,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBox x:Name="MotionPortEntry" Text="20777" Grid.Row="1" Grid.Column="1" Margin="0,5,15,5" Background="#717171" Foreground="White" BorderThickness="0" Padding="5"/>

                                    <TextBlock Text="Output Protocol:" Grid.Row="0" Grid.Column="2" Margin="15,5,15,5" Foreground="#DFBB3F" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <ComboBox x:Name="CmbMotionProtocol" Grid.Row="0" Grid.Column="3" Margin="0,5,0,5" Background="#717171" Foreground="#2F353D" BorderThickness="0" Padding="5">
                                        <ComboBoxItem Content="Raw OSC" IsSelected="True"/>
                                        <ComboBoxItem Content="SimTools String"/>
                                    </ComboBox>
                                </Grid>

                                <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                                    <CheckBox x:Name="ChkSafetyEnable" Content="Enable Safety Timeout (Zero out rig on disconnect)" Foreground="White" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Text="Timeout (ms):" Foreground="White" VerticalAlignment="Center" Margin="20,0,5,0"/>
                                    <TextBox x:Name="TxtSafetyTimeout" Text="500" Width="60" Background="#717171" Foreground="White" BorderThickness="0" Padding="2" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="Per-Axis Filtering &amp; Washout" Foreground="#DFBB3F" FontWeight="Bold" Margin="0,0,0,10"/>
                                <StackPanel x:Name="MotionAxesPanel" Margin="0,0,0,20"/>

                                <TextBlock Text="Telemetry Preview (DoF)" Foreground="#DFBB3F" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="20"/>
                                        <ColumnDefinition Width="60"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <TextBlock Text="Pitch" Grid.Row="0" Grid.Column="0" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,5"/>
                                    <ProgressBar x:Name="BarPitch" Grid.Row="0" Grid.Column="1" Minimum="-1" Maximum="1" Height="10" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="Roll" Grid.Row="1" Grid.Column="0" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,5"/>
                                    <ProgressBar x:Name="BarRoll" Grid.Row="1" Grid.Column="1" Minimum="-1" Maximum="1" Height="10" Margin="0,0,0,5"/>

                                    <TextBlock Text="Yaw" Grid.Row="2" Grid.Column="0" Foreground="White" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="BarYaw" Grid.Row="2" Grid.Column="1" Minimum="-1" Maximum="1" Height="10"/>

                                    <TextBlock Text="Surge" Grid.Row="0" Grid.Column="3" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,5"/>
                                    <ProgressBar x:Name="BarSurge" Grid.Row="0" Grid.Column="4" Minimum="-1" Maximum="1" Height="10" Margin="0,0,0,5"/>
                                    
                                    <TextBlock Text="Sway" Grid.Row="1" Grid.Column="3" Foreground="White" VerticalAlignment="Center" Margin="0,0,0,5"/>
                                    <ProgressBar x:Name="BarSway" Grid.Row="1" Grid.Column="4" Minimum="-1" Maximum="1" Height="10" Margin="0,0,0,5"/>

                                    <TextBlock Text="Heave" Grid.Row="2" Grid.Column="3" Foreground="White" VerticalAlignment="Center"/>
                                    <ProgressBar x:Name="BarHeave" Grid.Row="2" Grid.Column="4" Minimum="-1" Maximum="1" Height="10"/>
                                </Grid>
                            </StackPanel>
                        </Expander>

                        <Expander Margin="0,0,0,15" Padding="15" IsExpanded="True">
                            <Expander.Header>
                                <TextBlock Text="Incoming OSC Monitor (Terminal)" Foreground="#DFBB3F" FontSize="18" FontWeight="Bold"/>
                            </Expander.Header>
                            <StackPanel Margin="0,10,0,0">
                                
                                <Grid Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <CheckBox x:Name="ChkLogIncoming" Grid.Column="0" Content="Log Incoming Data" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" Checked="ChkLogIncoming_Checked" Unchecked="ChkLogIncoming_Unchecked"/>
                                    
                                    <StackPanel Orientation="Horizontal" Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Output Style:" Foreground="#DFBB3F" Margin="0,0,10,0" VerticalAlignment="Center" FontWeight="Bold"/>
                                        <RadioButton x:Name="RadioIncomingScroll" Content="Scrolling Log" IsChecked="True" Foreground="White" Margin="0,0,10,0" VerticalAlignment="Center" Checked="IncomingOutputStyle_Changed"/>
                                        <RadioButton x:Name="RadioIncomingInPlace" Content="In-Place Dashboard" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0" Checked="IncomingOutputStyle_Changed"/>
                                        <Button x:Name="BtnClearIncomingLog" Content="Clear" Width="80" Height="25" Background="#CC2900" Foreground="White" BorderThickness="0" FontWeight="Bold" Click="BtnClearIncomingLog_Click"/>
                                    </StackPanel>
                                </Grid>

                                <TextBox x:Name="IncomingLogArea" Height="250" Background="#2F353D" Foreground="#33FF00" FontFamily="Consolas" IsReadOnly="True" VerticalScrollBarVisibility="Auto" TextWrapping="Wrap" BorderBrush="#717171" Padding="10"/>
                            </StackPanel>
                        </Expander>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>